{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "src/**/*.{ts,tsx}",
      "tests/**/*.{ts,tsx}",
      "prisma/**",
      "*.{ts,mjs,json}",
      "!src/imports",
      "!src/main.tsx",
      "!src/app/App.tsx",
      "!src/app/components",
      "!src/app/contexts",
      "!vite.config.ts",
      "!postcss.config.mjs",
      "!.next"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "error"
      }
    }
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } }
}
