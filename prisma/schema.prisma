generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  name       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  testCases  TestCase[]
  testRuns   TestRun[]
}

model TestCase {
  id          String    @id @default(cuid())
  title       String
  description String?
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  testRuns    TestRun[]

  @@index([authorId])
}

model TestRun {
  id          String        @id @default(cuid())
  testCaseId  String
  testerId    String
  status      TestRunStatus @default(PENDING)
  notes       String?
  executedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  testCase    TestCase      @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  tester      User          @relation(fields: [testerId], references: [id], onDelete: Cascade)

  @@index([testCaseId])
  @@index([testerId])
}

enum TestRunStatus {
  PENDING
  PASSED
  FAILED
  BLOCKED
}
