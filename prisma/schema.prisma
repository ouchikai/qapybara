generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  QA
  DEVELOPER
  VIEWER
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ARCHIVED
}

enum IssueStatus {
  OPEN
  TRIAGED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TestCaseStatus {
  DRAFT
  READY
  PASSED
  FAILED
  ARCHIVED
}

enum BugSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum BugStatus {
  NEW
  IN_PROGRESS
  READY_FOR_TEST
  CLOSED
  REOPENED
}

enum NotificationType {
  INVITATION
  ASSIGNMENT
  TEST_FAILED
  BUG_STATUS_UPDATED
}

enum CustomFieldType {
  DROPDOWN
  TEXT
  TEXTAREA
}

model Organization {
  id            String       @id @default(cuid())
  slug          String       @unique
  name          String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?
  memberships   Membership[]
  repositories  Repository[]
  projects      Project[]
  issues        Issue[]
  testCases     TestCase[]
  customFieldDefinitions TestCaseCustomFieldDefinition[]
  bugs          Bug[]
  auditLogs     AuditLog[]
  notifications Notification[]
  outboxEvents  OutboxEvent[]

  @@index([deletedAt])
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  emailVerified  Boolean        @default(false)
  displayName    String
  image          String?
  passwordHash   String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  memberships    Membership[]
  accounts       Account[]
  sessions       Session[]
  assignedIssues Issue[]        @relation("IssueAssignee")
  assignedBugs   Bug[]          @relation("BugAssignee")
  notifications  Notification[]

  @@index([deletedAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
}

model Membership {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           UserRole
  status         MembershipStatus @default(INVITED)
  invitedAt      DateTime         @default(now())
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId, role])
  @@index([userId])
}

model Repository {
  id             String      @id @default(cuid())
  organizationId String
  slug           String
  name           String
  description    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  projects       Project[]
  customFields   TestCaseCustomFieldDefinition[]

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@index([organizationId, createdAt])
  @@index([deletedAt])
}

model Project {
  id             String        @id @default(cuid())
  organizationId String
  repositoryId   String
  slug           String
  name           String
  status         ProjectStatus @default(PLANNING)
  dueDate        DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  issues         Issue[]

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  repository   Repository   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, slug])
  @@index([organizationId, status, updatedAt])
  @@index([deletedAt])
}

model Issue {
  id                  String      @id @default(cuid())
  organizationId      String
  projectId           String
  externalIssueNumber Int?
  title               String
  description         String?
  status              IssueStatus @default(OPEN)
  assigneeId          String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  deletedAt           DateTime?
  testCases           TestCase[]
  bugs                Bug[]

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee     User?        @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@unique([projectId, externalIssueNumber])
  @@index([organizationId, status, updatedAt])
  @@index([assigneeId])
  @@index([deletedAt])
}

model TestCase {
  id             String         @id @default(cuid())
  organizationId String
  issueId        String
  title          String
  status         TestCaseStatus @default(DRAFT)
  assigneeId     String?
  executionCount Int            @default(0)
  lastExecutionAt DateTime?
  customFieldValues Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  bugs           Bug[]

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  issue        Issue        @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, updatedAt])
  @@index([issueId])
  @@index([deletedAt])
}

model TestCaseCustomFieldDefinition {
  id             String          @id @default(cuid())
  organizationId String
  repositoryId   String
  name           String
  description    String?
  fieldType      CustomFieldType
  options        Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  repository   Repository   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, name])
  @@index([organizationId, repositoryId])
}

model Bug {
  id             String      @id @default(cuid())
  organizationId String
  issueId        String
  testCaseId     String?
  title          String
  description    String?
  severity       BugSeverity
  status         BugStatus   @default(NEW)
  assigneeId     String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  issue        Issue        @relation(fields: [issueId], references: [id], onDelete: Cascade)
  testCase     TestCase?    @relation(fields: [testCaseId], references: [id], onDelete: SetNull)
  assignee     User?        @relation("BugAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, updatedAt])
  @@index([issueId])
  @@index([testCaseId])
  @@index([assigneeId])
  @@index([deletedAt])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorUserId    String?
  entityType     String
  entityId       String
  action         String
  payload        Json
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, entityType, entityId, createdAt])
}

model Notification {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  type           NotificationType
  title          String
  body           String
  readAt         DateTime?
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId, readAt, createdAt])
}

model OutboxEvent {
  id             String   @id @default(cuid())
  organizationId String
  aggregateType  String
  aggregateId    String
  eventType      String
  payload        Json
  publishedAt    DateTime?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, aggregateType, aggregateId, createdAt])
  @@index([publishedAt])
}
